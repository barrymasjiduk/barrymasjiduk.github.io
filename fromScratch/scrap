    document.addEventListener('DOMContentLoaded', () => {
        fetch('elm-prayer-times-2018.csv')
            .then(response => response.text())
            .then(data => {
                const prayerTimes = parseCSV(data);
                const currentDate = getCurrentDate();
                const todayPrayerTimes = prayerTimes.find(prayer => prayer.Date === currentDate);
    
                if (todayPrayerTimes) {
                    updateTime('fajr', 'begins', todayPrayerTimes.FajrBegins);
                    updateTime('fajr', 'jamat', todayPrayerTimes.FajrJamat);
                    updateTime('zuhr', 'begins', todayPrayerTimes.ZuhrBegins);
                    updateTime('zuhr', 'jamat', todayPrayerTimes.ZuhrJamat);
                    updateTime('asr', 'begins', todayPrayerTimes.AsrBegins);
                    updateTime('asr', 'jamat', todayPrayerTimes.AsrJamat);
                    updateTime('maghrib', 'begins', todayPrayerTimes.MaghribBegins);
                    updateTime('maghrib', 'jamat', todayPrayerTimes.MaghribJamat);
                    updateTime('isha', 'begins', todayPrayerTimes.IshaBegins);
                    updateTime('isha', 'jamat', todayPrayerTimes.IshaJamat);
                }
            })
            .catch(error => console.error('Error fetching the CSV file:', error));
    });
    
    function parseCSV(data) {
        const rows = data.split('\n').map(row => row.split(','));
        const headers = rows[0];
        return rows.slice(1).map(row => {
            return headers.reduce((acc, header, i) => {
                acc[header] = row[i];
                return acc;
            }, {});
        });
    }
    
    function getCurrentDate() {
        const now = new Date();
        return now.toISOString().split('T')[0];
    }
    
    function updateTime(prayer, type, time) {
        const selector = `[data-time="${prayer}-${type}"]`;
        const element = document.querySelector(selector);
        if (element) {
            element.textContent = time;
        }
    }
    






